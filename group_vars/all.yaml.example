---
# Copy this file to group_vars/all.yaml (gitignored) to set per-deployment
# values for all playbooks — it loads as inventory group_vars for the `all`
# group (it sits next to inventory.ini, so run ansible-playbook from the repo
# root).
#
# PRECEDENCE RULE: group_vars only take effect for variables the playbooks do
# NOT define in their play `vars:` (play vars silently shadow group_vars, and
# -e beats both). Playbooks in this repo keep their repo defaults at the use
# site via `| default(...)` precisely so these overrides work — when adding a
# new overridable value, follow that pattern instead of hardcoding it in vars.
syncthing_drop_dir: "/mnt/pve/secure-storage/syncthing_share/my-personal-sync/tech/backups"
target_disk: "/dev/sda"
vaultwarden_ip: "192.168.0.77"    # LAN IP of the VaultWarden LXC 101 (repo default 192.168.0.54)
vaultwarden_ip_suffix: "77"       # last octet 06 assigns at provision time — keep in step with vaultwarden_ip
# NOTE: do NOT set backups_root here. Inside the playbooks that name is the
# ON-BOX snapshot root on the encrypted volume (vaultwarden_backups /
# immich_db_backups); redirecting it into a Syncthing-shared folder would sync
# PLAINTEXT vault/DB snapshots off the box. The synced drop folder is
# controlled by syncthing_drop_dir only.
