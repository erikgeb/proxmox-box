# Copy to `caddy.env` (same directory) and fill in before deploying. `caddy.env`
# is gitignored; never commit the real file. Read by the `caddy` service in
# docker-compose.yml and substituted into the Caddyfile at load time.
#
# Unlike the DB password (auto-generated once on the box), these are OVH API
# credentials the owner holds, so they are supplied here and pushed into the
# container by 05_deploy_docker_stack.yaml.

# Contact address Let's Encrypt uses for expiry/issuance notices.
ACME_EMAIL=you@example.com

# Base domain the wildcard cert is issued for: *.BASE_DOMAIN. Services are then
# reached at immich.BASE_DOMAIN, syncthing.BASE_DOMAIN, etc.
BASE_DOMAIN=home.example.com

# OVH API endpoint region. One of:
#   ovh-eu | ovh-ca | ovh-us | kimsufi-eu | kimsufi-ca | soyoustart-eu | soyoustart-ca
OVH_ENDPOINT=ovh-eu

# OVH API credentials. Create at https://api.ovh.com/createToken/ (or
# https://eu.api.ovh.com/createToken/) with rights GET/POST/PUT/DELETE on
# /domain/zone/* so Caddy can write the _acme-challenge TXT records.
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
