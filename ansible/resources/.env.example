# Copy to `.env` (same directory) and fill in before `docker compose up`.
# `.env` is gitignored; never commit the real file.
#
# These are read by both the immich-server and database services. The server
# defaults DB_HOSTNAME=database and REDIS_HOSTNAME=redis, which match the
# service names in docker-compose.yml, so they don't need to be set here.

# Pins both immich-server and the immich-machine-learning "-openvino" image.
# v3.0.2 = latest stable as of 2026-07-14. Use "v3" to track the v3 series, or
# "release" to always pull the newest stable (less reproducible).
# NOTE: this file is generate-once on the box — editing it here does NOT
# propagate to a deployed stack. Bump a live deployment with
# `update_docker_stack.yaml -e immich_version=...` instead.
IMMICH_VERSION=v3.0.2

# PostgreSQL credentials. Generate a strong DB_PASSWORD (the DB is only reachable
# inside the compose network — no ports are published — but use a real secret).
DB_USERNAME=postgres
DB_PASSWORD=changeme_use_a_strong_password
DB_DATABASE_NAME=immich
